{
  "enabled": true,
  "storage": {
    "backend": "json",
    "path": "./data/workflows.json",
    "cleanupIntervalMs": 300000
  },
  "defaults": {
    "timeoutMs": 1800000,
    "caseInsensitiveTriggers": true,
    "allowOneActiveWorkflowPerConversation": true,
    "summarizeBeforeConfirm": true,
    "conversationKeyStrategy": "channel+chat+user"
  },
  "commands": {
    "cancel":     ["cancel", "stop", "never mind", "nevermind"],
    "restart":    ["start over", "restart"],
    "skip":       ["skip"],
    "help":       ["help", "?"],
    "confirmYes": ["yes", "y", "confirm", "yeah", "yep", "ok", "okay"],
    "confirmNo":  ["no", "n", "nope"]
  },
  "completion": {
    "handlers": [
      { "type": "chat-confirm" },
      { "type": "log" },
      { "type": "file", "options": { "path": "./data/completions.jsonl" } }
    ]
  },
  "workflows": [
    {
      "id": "new_event",
      "displayName": "New Event",
      "description": "Capture details for a new calendar event.",
      "enabled": true,
      "channels": ["telegram", "webchat"],
      "triggers": ["New Event", "Add Event", "Schedule Meeting"],
      "confirmBeforeComplete": true,
      "startMessage": "Let's create a new event.",
      "completeMessage": "Event captured.",
      "cancelMessage": "Okay — cancelled the event.",
      "steps": [
        {
          "field": "title",
          "type": "text",
          "prompt": "What is the event title?",
          "required": true,
          "validate": { "minLength": 1, "maxLength": 200 },
          "transform": "trim"
        },
        {
          "field": "date",
          "type": "date",
          "prompt": "What day is it?",
          "retryPrompt": "I didn't catch that date. Try something like 'Friday', 'tomorrow', or '2026-05-03'.",
          "required": true
        },
        {
          "field": "time",
          "type": "time",
          "prompt": "What time?",
          "retryPrompt": "Please give me a time like '1 PM', '13:00', or '9:30am'.",
          "required": true
        },
        {
          "field": "location",
          "type": "location",
          "prompt": "Where is it?",
          "required": false,
          "skippable": true
        }
      ]
    }
  ]
}
