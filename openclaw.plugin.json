{
  "$schema": "https://openclaw.dev/schema/plugin.schema.json",
  "id": "openclaw-plugin-router",
  "name": "Conversation Workflow Router",
  "version": "1.0.0",
  "description": "Stateful inbound conversational workflow router. Detects trigger phrases (e.g. 'New Event'), starts multi-turn dialogs, persists state across messages, resumes on next reply, validates answers, and routes completed structured payloads to configurable downstream handlers.",
  "author": "Jamen Enterprises",
  "license": "MIT",
  "type": "native",
  "runtime": "node",
  "entrypoint": "dist/index.js",
  "exports": {
    "activate": "activate",
    "deactivate": "deactivate"
  },
  "capabilities": [
    "message.intercept",
    "message.reply",
    "state.persist",
    "lifecycle.hook"
  ],
  "hooks": [
    "message:received",
    "message:preprocessed",
    "session:ended",
    "plugin:activated",
    "plugin:deactivated"
  ],
  "channels": {
    "supported": ["telegram", "webchat", "cli", "generic"],
    "default": ["telegram", "webchat"]
  },
  "permissions": {
    "storage": "plugin-scoped",
    "network": "none",
    "readMessages": true,
    "sendMessages": true
  },
  "configSchema": "./schema/config.schema.json",
  "defaultConfig": "./example.config.json",
  "workflowsDir": "./workflows",
  "tags": ["workflow", "router", "dialog", "telegram", "webchat"],
  "compatibility": {
    "openclaw": ">=0.1.0"
  }
}
