{
  "id": "openclaw-plugin-router",
  "name": "Conversation Workflow Router",
  "description": "Stateful inbound conversational workflow router. Detects trigger phrases (e.g. 'New Event'), runs multi-turn dialogs, persists state across messages, resumes on the next reply, validates answers, and routes completed structured payloads to configurable downstream handlers.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Master switch for the entire plugin."
      },
      "storage": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "backend": { "type": "string", "enum": ["json", "memory"], "default": "json" },
          "path": { "type": "string", "default": "workflows.json" },
          "cleanupIntervalMs": { "type": "integer", "minimum": 0, "default": 300000 }
        }
      },
      "defaults": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "timeoutMs": { "type": "integer", "minimum": 0, "default": 1800000 },
          "caseInsensitiveTriggers": { "type": "boolean", "default": true },
          "allowOneActiveWorkflowPerConversation": { "type": "boolean", "default": true },
          "summarizeBeforeConfirm": { "type": "boolean", "default": true },
          "conversationKeyStrategy": {
            "type": "string",
            "enum": ["channel+chat+user", "channel+user", "session"],
            "default": "channel+chat+user"
          }
        }
      },
      "commands": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "cancel":     { "type": "array", "items": { "type": "string" } },
          "restart":    { "type": "array", "items": { "type": "string" } },
          "skip":       { "type": "array", "items": { "type": "string" } },
          "help":       { "type": "array", "items": { "type": "string" } },
          "confirmYes": { "type": "array", "items": { "type": "string" } },
          "confirmNo":  { "type": "array", "items": { "type": "string" } }
        }
      },
      "completion": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "handlers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "type": "string", "enum": ["log", "chat-confirm", "callback", "command", "file"] },
                "options": { "type": "object" }
              }
            }
          }
        }
      },
      "workflows": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "triggers", "steps"],
          "properties": {
            "id":            { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
            "displayName":   { "type": "string" },
            "description":   { "type": "string" },
            "enabled":       { "type": "boolean", "default": true },
            "channels":      { "type": "array", "items": { "type": "string" } },
            "triggers":      { "type": "array", "items": { "type": "string" } },
            "triggerRegex":  { "type": "array", "items": { "type": "string" } },
            "timeoutMs":     { "type": "integer", "minimum": 0 },
            "confirmBeforeComplete": { "type": "boolean", "default": true },
            "onComplete":    { "type": "array", "items": { "type": "object" } },
            "startMessage":  { "type": "string" },
            "cancelMessage": { "type": "string" },
            "completeMessage":{ "type": "string" },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["field", "prompt"],
                "properties": {
                  "field":       { "type": "string", "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$" },
                  "type":        { "type": "string", "enum": ["text", "boolean", "date", "time", "datetime", "number", "choice", "location", "email", "phone"], "default": "text" },
                  "prompt":      { "type": "string" },
                  "help":        { "type": "string" },
                  "required":    { "type": "boolean", "default": true },
                  "default":     {},
                  "choices":     { "type": "array", "items": { "type": "string" } },
                  "retryPrompt": { "type": "string" },
                  "skippable":   { "type": "boolean", "default": false },
                  "validate": {
                    "type": "object",
                    "properties": {
                      "minLength": { "type": "integer", "minimum": 0 },
                      "maxLength": { "type": "integer", "minimum": 0 },
                      "pattern":   { "type": "string" },
                      "min":       { "type": "number" },
                      "max":       { "type": "number" }
                    }
                  },
                  "transform":   { "type": "string", "enum": ["lowercase", "uppercase", "trim", "titlecase"] },
                  "next":        { "type": "string" },
                  "branches": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["when", "next"],
                      "properties": {
                        "when": { "type": "string" },
                        "next": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
