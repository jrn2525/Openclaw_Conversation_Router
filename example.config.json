{
  "_comment": [
    "This is an OpenClaw config snippet. Merge it into your OpenClaw config.",
    "The plugin reads its config from plugins.entries.conversation-router.config.",
    "A plugin with NO workflows configured will load but never match any trigger —",
    "the plugin logs an error in that case so you notice."
  ],

  "plugins": {
    "entries": {
      "conversation-router": {
        "config": {
          "enabled": true,

          "storage": {
            "backend": "json",
            "path": "workflows.json",
            "cleanupIntervalMs": 300000
          },

          "defaults": {
            "timeoutMs": 1800000,
            "caseInsensitiveTriggers": true,
            "allowOneActiveWorkflowPerConversation": true,
            "summarizeBeforeConfirm": true,
            "conversationKeyStrategy": "channel+chat+user"
          },

          "commands": {
            "cancel":     ["cancel", "stop", "never mind", "nevermind"],
            "restart":    ["start over", "restart"],
            "skip":       ["skip"],
            "help":       ["help", "?"],
            "confirmYes": ["yes", "y", "confirm", "yeah", "yep", "ok", "okay"],
            "confirmNo":  ["no", "n", "nope"]
          },

          "completion": {
            "handlers": [
              { "type": "chat-confirm" },
              { "type": "log" },
              { "type": "file", "options": { "path": "completions.jsonl" } }
            ]
          },

          "workflows": [
            {
              "id": "new_event",
              "displayName": "New Event",
              "description": "Capture details for a new calendar event.",
              "enabled": true,
              "channels": ["telegram", "webchat"],
              "triggers": ["New Event", "Add Event", "Schedule Meeting"],
              "confirmBeforeComplete": true,
              "startMessage": "",
              "completeMessage": "Got it. The event details are saved.",
              "cancelMessage": "Okay, cancelled the event.",
              "steps": [
                {
                  "field": "title",
                  "type": "text",
                  "prompt": "What is the event title?",
                  "required": true,
                  "validate": { "minLength": 1, "maxLength": 200 },
                  "transform": "trim"
                },
                {
                  "field": "date",
                  "type": "date",
                  "prompt": "What day is it?",
                  "retryPrompt": "I didn't catch that date. Try 'Friday', 'tomorrow', or '04/28/2026'.",
                  "required": true
                },
                {
                  "field": "time",
                  "type": "time",
                  "prompt": "What time?",
                  "retryPrompt": "Please give me a time like '1 PM', '13:00', or '9:00 am'.",
                  "required": true
                },
                {
                  "field": "location",
                  "type": "location",
                  "prompt": "Where is it?",
                  "required": false,
                  "skippable": true
                }
              ]
            }
          ]
        }
      }
    }
  }
}
